<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Team | SatDoctor</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
            background-color: #f6f8fa;
        }
        nav {
            padding: 20px 0;
            border-bottom: 1px solid #d0d7de;
            margin-bottom: 40px;
        }
        nav a {
            text-decoration: none;
            color: #0969da;
            margin-right: 20px;
            font-weight: bold;
        }
        h1 {
            text-align: center;
            color: #24292f;
            margin-bottom: 50px;
        }
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }
        .card {
            background: #fff;
            border: 1px solid #d0d7de;
            border-radius: 6px;
            padding: 24px;
            text-align: center;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 24px rgba(149,157,165,0.2);
        }
        .photo-placeholder {
            width: 120px;
            height: 120px;
            background-color: #eaeef2;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: #afb8c1;
        }
        h2 {
            margin: 10px 0 5px;
            font-size: 1.5rem;
        }
        .title {
            color: #57606a;
            font-weight: 600;
            margin-bottom: 15px;
            display: block;
        }
        .bio {
            font-size: 0.95rem;
            color: #24292f;
        }
        .social-link {
            display: inline-block;
            margin-top: 15px;
            color: #0969da;
            text-decoration: none;
            font-size: 0.9rem;
        }
        footer {
            margin-top: 60px;
            text-align: center;
            font-size: 0.8rem;
            color: #6e7781;
        }
    </style>
</head>
<body>

    <nav>
        <a href="index.html">← Back to Home</a>
    </nav>

    <h1>The Founders</h1>

    <div class="team-grid">
        <!-- Co-founder 1 -->
        <div class="card">
            <div class="photo-placeholder">👤</div>
            <h2>Co-founder Name</h2>
            <span class="title">Chief Executive Officer</span>
            <p class="bio">Expert in aerospace engineering and system architecture. Leading the vision to streamline satellite diagnostics and operations.</p>
            <a href="#" class="social-link">LinkedIn Profile</a>
        </div>

        <!-- Co-founder 2 -->
        <div class="card">
            <div class="photo-placeholder">👤</div>
            <h2>Co-founder Name</h2>
            <span class="title">Chief Technology Officer</span>
            <p class="bio">Specializing in signal processing and orbital mechanics. Focused on building the core infrastructure of the SatDoctor platform.</p>
            <a href="#" class="social-link">LinkedIn Profile</a>
        </div>
    </div>

    <footer>
        <p>&copy; 2024 SatDoctor. Built with GitHub Pages.</p>
    </footer>

</body>
</html>
